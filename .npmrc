# Expo / Metro resolve a flat node_modules far more reliably than pnpm's
# default symlinked layout — node-linker=hoisted is Expo's documented
# recommendation for pnpm monorepos (https://docs.expo.dev/guides/monorepos/).
#
# A single flat tree means one React copy workspace-wide. Expo SDK 52 hard-
# requires React 18.3 (RN 0.76), so the whole monorepo is pinned to React
# 18.3 via pnpm.overrides — Next.js 15.1 fully supports React 18.3, so the
# web app is unaffected functionally.
node-linker=hoisted
