# Expo / Metro resolve a flat node_modules far more reliably than pnpm's
# default symlinked layout — node-linker=hoisted is Expo's documented
# recommendation for pnpm monorepos (https://docs.expo.dev/guides/monorepos/).
#
# A single flat tree means one React copy workspace-wide. Expo SDK 54 ships
# React 19.1 (RN 0.81), so the whole monorepo is pinned to React 19.1 via
# pnpm.overrides — Next.js 16 supports React ^19.0, so the web app is
# unaffected functionally.
node-linker=hoisted
