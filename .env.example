# ============================================================================
# Hadith Search — Environment Variables
# ============================================================================
# Copy this file to .env.local and fill in real values for local development.
# Never commit .env or .env.local — only .env.example is tracked.
# ============================================================================

# ----------------------------------------------------------------------------
# Supabase (https://supabase.com/dashboard)
# ----------------------------------------------------------------------------
# Public URL and anon key are safe in the browser bundle (RLS protects rows).
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key is SERVER-ONLY. Never expose to the browser.
# Used by the Next.js /api/* services for RPC calls, cache writes, and
# analytics inserts (RLS-bypassed).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ----------------------------------------------------------------------------
# Cohere (https://dashboard.cohere.com/api-keys)
# ----------------------------------------------------------------------------
# Used by /api/search for query embedding (embed-v4.0) and reranking
# (rerank-v4.0-pro). Server-only — never expose to the browser.
#
# If unset, search still works but degrades to FTS-only + stub embedding,
# and responses carry `degraded: true`. Required for the one-time embedding
# ingest unless EMBED_PROVIDER=bge-local (see below).
COHERE_API_KEY=your-cohere-api-key-here

# ----------------------------------------------------------------------------
# Embedding provider — Cohere (default) vs local BGE-M3
# ----------------------------------------------------------------------------
# "cohere" (default): query + document embeds via Cohere embed-v4.0.
# "bge-local": route ALL embeds to a local BGE-M3 server (scripts/bge_m3_server.py),
#   no API key, runs offline on Apple MPS / CUDA / CPU. Both are 1024-dim, so
#   switching needs no DB migration — but you MUST re-embed the corpus AND set
#   the same provider for query-time, or query/document vectors won't match.
#   Setup:
#     python3 -m venv scripts/bge-m3-venv
#     scripts/bge-m3-venv/bin/pip install torch sentence-transformers fastapi "uvicorn[standard]"
#     scripts/bge-m3-venv/bin/python scripts/bge_m3_server.py   # → :8000
#   Re-embed: node --conditions=react-server --env-file=.env.local \
#     --import tsx apps/web/scripts/ingest-embeddings.ts
# EMBED_PROVIDER=bge-local
# BGE_EMBED_URL=http://127.0.0.1:8000

# When EMBED_PROVIDER=bge-local, reranking also runs locally via the
# bge-reranker-v2-m3 cross-encoder served by the SAME scripts/bge_m3_server.py
# (the local, free equivalent of Cohere rerank-v4.0-pro). The reranker loads
# automatically; skip it (and its ~2GB download) with BGE_RERANK_ENABLED=0 on
# the server. Defaults below need no override.
# BGE_RERANK_URL=http://127.0.0.1:8000
# BGE_RERANK_TIMEOUT_MS=20000

# Kill switch for the reranker (in case of cost spike or outage).
# When "true", /api/search returns RRF-ordered results without reranking.
# IMPORTANT: keep this "false" — the reranker is the primary relevance lever.
RERANK_DISABLED=false

# Pipeline tunables (sane defaults; only override if you know why).
EMBED_TIMEOUT_MS=1500
RERANK_TIMEOUT_MS=2000
# Hybrid candidate pool handed to the reranker (FTS + vector, RRF-fused). Each
# candidate is one cross-encoder pass; ~40 reranks in ~4-5s on local MPS. Raise
# it (toward the RPC cap of 100) when reranking on a GPU or via Cohere.
RETRIEVE_COUNT=40
# Minimum reranker relevance for a result to be shown. Calibrated to
# bge-reranker-v2-m3, whose scores are compressed low (real matches ~0.02–0.9,
# unrelated ~0.0000) — so the floor is ~0.02, NOT a Cohere-style 0.3. Raise to
# cut more of the tail; lower to surface weaker matches. With Cohere rerank
# (whose scores spread across [0,1]), raise this toward ~0.2–0.3.
MIN_RELEVANCE=0.02
CACHE_TTL_DAYS=7
RATE_LIMIT_PER_SEC=10
RATE_LIMIT_BURST=30
# Max number of distinct IP buckets the rate limiter tracks per isolate.
# Caps memory under header-cycling attack patterns.
RATE_LIMIT_BUCKETS_MAX=10000
# Per-isolate LRU in front of the Postgres query_cache.
LRU_TTL_MS=300000
LRU_CAPACITY=50
# Set to "true" only when running behind a reverse proxy you trust to set
# X-Forwarded-For correctly (Vercel sets X-Vercel-Forwarded-For instead, which
# the rate limiter already trusts and clients cannot spoof).
TRUSTED_PROXY=false

# ----------------------------------------------------------------------------
# Site (used for absolute URLs in metadata, sitemap, robots, OG images)
# ----------------------------------------------------------------------------
# Set to your production origin (e.g. https://hadith.example.com). Falls back
# to http://localhost:3000 in dev. Vercel preview deploys should set this to
# the preview URL via project env vars.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ----------------------------------------------------------------------------
# Sentry (https://sentry.io)
# ----------------------------------------------------------------------------
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
# Suppress @sentry/nextjs build warning for the optional global-error.tsx
# (we provide one, so this is informational only).
SENTRY_SUPPRESS_GLOBAL_ERROR_HANDLER_FILE_WARNING=1

# ----------------------------------------------------------------------------
# PostHog (https://posthog.com)
# ----------------------------------------------------------------------------
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ============================================================================
# Mobile app (apps/mobile) — Expo
# ============================================================================
# Expo only inlines vars prefixed EXPO_PUBLIC_. Put these in apps/mobile/.env
# (or .env.local).
#
# EXPO_PUBLIC_API_URL points at the deployed (or local) Next.js service.
# Simulator/emulator: http://localhost:3000 works.
# Physical iPhone/Android device: set to your laptop's LAN IP (e.g.
# http://192.168.1.42:3000) — localhost on the device resolves to the device
# itself, not your dev machine.
EXPO_PUBLIC_API_URL=http://localhost:3000

EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
EXPO_PUBLIC_POSTHOG_KEY=
EXPO_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
EXPO_PUBLIC_SENTRY_DSN=
# REQUIRED for production share links — set to your canonical web host
# (e.g. https://hadith.example.com/hadith/). The placeholder default below
# WILL leak into share sheets if you forget to set it.
EXPO_PUBLIC_SHARE_BASE_URL=https://hadithapp.tld/hadith/
