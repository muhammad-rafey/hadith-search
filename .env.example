# ============================================================================
# Hadith Search — Environment Variables
# ============================================================================
# Copy this file to .env.local and fill in real values for local development.
# Never commit .env or .env.local — only .env.example is tracked.
# ============================================================================

# ----------------------------------------------------------------------------
# Supabase (https://supabase.com/dashboard)
# ----------------------------------------------------------------------------
# Public URL and anon key are safe in the browser bundle (RLS protects rows).
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key is SERVER-ONLY. Never expose to the browser.
# Used by the search Edge Function for RPC calls, cache writes, and analytics inserts.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ----------------------------------------------------------------------------
# Cohere (https://dashboard.cohere.com/api-keys)
# ----------------------------------------------------------------------------
# Used by the search Edge Function for query embedding and reranking.
# Server-only — never expose to the browser.
COHERE_API_KEY=your-cohere-api-key-here

# Kill switch for the reranker (in case of cost spike or outage).
# When "true", the search function returns RRF-ordered results without reranking.
RERANK_DISABLED=false

# ----------------------------------------------------------------------------
# OpenAI (https://platform.openai.com/api-keys) — fallback embedder
# ----------------------------------------------------------------------------
# Optional. Only used if Cohere times out and the fallback feature flag is on.
# Marked out of scope for MVP per plan/01-search-api.md.
OPENAI_API_KEY=

# ----------------------------------------------------------------------------
# Site (used for absolute URLs in metadata, sitemap, robots, OG images)
# ----------------------------------------------------------------------------
# Set to your production origin (e.g. https://hadith.example.com). Falls back
# to http://localhost:3000 in dev. Vercel preview deploys should set this to
# the preview URL via project env vars.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ----------------------------------------------------------------------------
# Sentry (https://sentry.io)
# ----------------------------------------------------------------------------
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
# Suppress @sentry/nextjs build warning for the optional global-error.tsx
# (we provide one, so this is informational only).
SENTRY_SUPPRESS_GLOBAL_ERROR_HANDLER_FILE_WARNING=1

# ----------------------------------------------------------------------------
# PostHog (https://posthog.com)
# ----------------------------------------------------------------------------
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ============================================================================
# Mobile app (apps/mobile) — Expo
# ============================================================================
# Expo only inlines vars prefixed EXPO_PUBLIC_. Put these in apps/mobile/.env
# (or .env.local). When all are empty the app runs fully in mock mode against
# the bundled sample corpus — identical to the web's placeholder behavior.
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
EXPO_PUBLIC_POSTHOG_KEY=
EXPO_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
EXPO_PUBLIC_SENTRY_DSN=
# Base URL for share links (defaults to the planned canonical web host).
EXPO_PUBLIC_SHARE_BASE_URL=https://hadithapp.tld/hadith/
