{
  "name": "hadith-search",
  "version": "0.0.1",
  "private": true,
  "description": "Semantic search over Sahih al-Bukhari (web first, mobile later)",
  "packageManager": "pnpm@10.0.0",
  "engines": {
    "node": ">=20.19.4"
  },
  "scripts": {
    "dev": "pnpm --filter @hadith/web dev",
    "mobile": "pnpm --filter @hadith/mobile start",
    "build": "pnpm -r --parallel build",
    "lint": "pnpm -r --parallel lint",
    "typecheck": "pnpm -r --parallel typecheck",
    "format": "biome format --write .",
    "format:check": "biome format ."
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "typescript": "^5.6.3"
  },
  "pnpm": {
    "overrides": {
      "react-native-reanimated": "~3.16.7",
      "react-native-css-interop": "0.1.22"
    }
  }
}
